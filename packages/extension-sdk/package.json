{
  "name": "@neo-anki/extension-sdk",
  "version": "2.1.0",
  "description": "Isolated, patch-based TypeScript SDK and build tooling for Neo Anki extensions.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist", "bin", "README.md"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "neo-anki-extension": "./bin/neo-anki-extension.mjs"
  },
  "scripts": {
    "prebuild": "npm run build -w @neo-anki/compatibility-domain",
    "build": "tsc -p tsconfig.json",
    "precheck": "npm run build -w @neo-anki/compatibility-domain",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@neo-anki/compatibility-domain": "0.2.0",
    "esbuild": "^0.28.1",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "typescript": "~7.0.2"
  }
}
