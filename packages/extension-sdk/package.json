{
  "name": "@neo-anki/extension-sdk",
  "version": "1.0.0",
  "description": "Public TypeScript SDK and build tooling for Neo Anki extensions.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist", "bin", "README.md"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "neo-anki-extension": "./bin/neo-anki-extension.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "esbuild": "^0.28.1",
    "fflate": "^0.8.3",
    "ts-fsrs": "^5.2.0"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "~7.0.2"
  }
}
