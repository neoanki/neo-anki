{
  "name": "neo-anki",
  "productName": "Neo Anki",
  "description": "A calm, time-aware, local-first spaced repetition desktop app.",
  "author": "Neo Anki contributors",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc -b && vite build",
    "desktop:prepare": "esbuild electron/main.ts --bundle --platform=node --format=esm --external:electron --outfile=dist-electron/main.mjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist-electron/preload.cjs",
    "desktop:dev": "npm run desktop:prepare && concurrently -k \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "desktop:pack": "npm run build && npm run desktop:prepare && electron-builder --dir",
    "desktop:build": "npm run build && npm run desktop:prepare && electron-builder",
    "test:desktop": "npm run build && npm run desktop:prepare && playwright test --config=playwright.desktop.config.ts",
    "typecheck": "tsc -b && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:all": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run test:e2e && npm run test:desktop"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "fzstd": "^0.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.14.1",
    "ts-fsrs": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "app.neoanki.desktop",
    "productName": "Neo Anki",
    "asar": true,
    "directories": { "output": "release", "buildResources": "build" },
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"],
      "identity": null
    },
    "win": { "target": "nsis", "icon": "build/icon.png" },
    "linux": { "category": "Education", "target": "AppImage", "icon": "build/icon.png" }
  }
}
